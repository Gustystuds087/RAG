# ---- Neo4j (graph + vectors; get these from a Neo4j Aura free instance) ----
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ---- Gemini (primary LLM: Cypher generation + answers) ----
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# ---- Groq (used for the guardrail classifier; free at https://console.groq.com/keys) ----
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embedding model (downloaded automatically on first run) ----
EMBED_MODEL=all-mpnet-base-v2

# ---- Data (used only by graph_loader when (re)building the graph) ----
DATA_CSV=data/medicine_dataset.csv
