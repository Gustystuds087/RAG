# COPY THIS into Streamlit Cloud -> App settings -> Secrets (paste box).
# Do NOT commit a real secrets.toml — it's git-ignored.

NEO4J_URI = "neo4j+ssc://xxxxxxxx.databases.neo4j.io"
NEO4J_USER = "xxxxxxxx"
NEO4J_PASSWORD = "your-neo4j-password"
NEO4J_DATABASE = "xxxxxxxx"

GROQ_API_KEY = "gsk_your_new_rotated_key"
GROQ_MODEL = "llama-3.3-70b-versatile"

EMBED_MODEL = "all-mpnet-base-v2"

# Direct-download URL to your zipped Chroma folder (e.g. Hugging Face).
CHROMA_URL = "https://huggingface.co/datasets/USERNAME/medgraphy-chroma/resolve/main/chroma.zip"
CHROMA_DIR = "artifacts/chroma"
CHROMA_COLLECTION = "medicines"

ANONYMIZED_TELEMETRY = "False"
