# ---- Neo4j (get these from Neo4j Aura free instance) ----
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---- Groq (get a free key at https://console.groq.com/keys) ----
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embedding model (downloaded automatically on first run) ----
EMBED_MODEL=all-mpnet-base-v2

# ---- Data / vector store paths ----
DATA_CSV=data/medicines.csv
CHROMA_DIR=artifacts/chroma
CHROMA_COLLECTION=medicines

# Silence ChromaDB's harmless telemetry warnings
ANONYMIZED_TELEMETRY=False
